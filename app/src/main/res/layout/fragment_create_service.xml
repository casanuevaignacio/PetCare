<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="20dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Publicar mi Servicio"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:textColor="#333333"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título del servicio (Ej: Paseo de perros grandes)"
            android:textSize="14sp"
            android:textColor="#666666"/>

        <EditText
            android:id="@+id/etServiceTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título breve"
            android:inputType="textCapSentences"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción detallada"
            android:textSize="14sp"
            android:textColor="#666666"/>

        <EditText
            android:id="@+id/etServiceDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Cuéntanos qué incluye tu cuidado..."
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precio por hora o día ($)"
            android:textSize="14sp"
            android:textColor="#666666"/>

        <EditText
            android:id="@+id/etServicePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: 15.00"
            android:inputType="numberDecimal"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnPublishService"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="PUBLICAR AHORA"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>